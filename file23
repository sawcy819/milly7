<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dark Login Page</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:#0f172a;
      overflow:hidden;
    }

    body::before{
      content:'';
      position:absolute;
      width:500px;
      height:500px;
      background:linear-gradient(#00f5ff,#8b5cf6);
      border-radius:50%;
      top:-150px;
      right:-100px;
      filter:blur(120px);
      opacity:0.5;
    }

    body::after{
      content:'';
      position:absolute;
      width:400px;
      height:400px;
      background:linear-gradient(#2563eb,#06b6d4);
      border-radius:50%;
      bottom:-150px;
      left:-100px;
      filter:blur(120px);
      opacity:0.4;
    }

    .login-container{
      position:relative;
      width:360px;
      padding:40px;
      background:rgba(15, 23, 42, 0.8);
      border:1px solid rgba(255,255,255,0.1);
      border-radius:20px;
      backdrop-filter:blur(15px);
      box-shadow:0 8px 32px rgba(0,0,0,0.4);
      z-index:1;
    }

    .login-container h1{
      color:white;
      text-align:center;
      margin-bottom:30px;
      font-size:32px;
    }

    .input-group{
      margin-bottom:20px;
    }

    .input-group label{
      color:#cbd5e1;
      display:block;
      margin-bottom:8px;
      font-size:14px;
    }

    .input-group input{
      width:100%;
      padding:14px;
      border:none;
      outline:none;
      border-radius:10px;
      background:#1e293b;
      color:white;
      font-size:15px;
      transition:0.3s;
    }

    .input-group input:focus{
      border:1px solid #38bdf8;
      box-shadow:0 0 10px rgba(56,189,248,0.4);
    }

    .options{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:25px;
      color:#94a3b8;
      font-size:14px;
    }

    .options a{
      color:#38bdf8;
      text-decoration:none;
    }

    .options a:hover{
      text-decoration:underline;
    }

    .login-btn{
      width:100%;
      padding:14px;
      border:none;
      border-radius:10px;
      background:linear-gradient(90deg,#06b6d4,#3b82f6);
      color:white;
      font-size:16px;
      font-weight:bold;
      cursor:pointer;
      transition:0.3s;
    }

    .login-btn:hover{
      transform:translateY(-2px);
      opacity:0.9;
    }

    .signup{
      text-align:center;
      margin-top:20px;
      color:#94a3b8;
      font-size:14px;
    }

    .signup a{
      color:#38bdf8;
      text-decoration:none;
      font-weight:bold;
    }

    .signup a:hover{
      text-decoration:underline;
    }
  </style>
</head>

<body>

  <div class="login-container">
    <h1>Welcome Back</h1>

    <form>
      <div class="input-group">
        <label>Email</label>
        <input type="email" placeholder="Enter your email" required>
      </div>

      <div class="input-group">
        <label>Password</label>
        <input type="password" placeholder="Enter your password" required>
      </div>

      <div class="options">
        <label>
          <input type="checkbox">
          Remember me
        </label>

        <a href="#">Forgot Password?</a>
      </div>

      <button type="submit" class="login-btn">Login</button>

      <div class="signup">
        Don't have an account?
        <a href="#">Sign Up</a>
      </div>
    </form>
  </div>

</body>
</html>
